# Google Gemini
GOOGLE_API_KEY=your_google_ai_api_key_here

# App / environment
APP_ENV=development

# Inngest
INNGEST_APP_ID=rag_app
INNGEST_IS_PRODUCTION=false

# Required in production so incoming webhook signatures can be verified.
INNGEST_SIGNING_KEY=your_inngest_signing_key_here

# Optional for sending events through Inngest Cloud instead of local tooling.
INNGEST_EVENT_KEY=your_inngest_event_key_here

# Local/dev API base polled by the Streamlit app for run output.
# For security, this app only supports localhost/127.0.0.1 here.
INNGEST_API_BASE=http://127.0.0.1:8288/v1

# Qdrant
QDRANT_URL=http://127.0.0.1:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=docs

# Model configuration
EMBED_MODEL=gemini-embedding-001
EMBED_DIM=3072
LLM_MODEL=gemini-3-flash-preview

# Upload / query limits
MAX_PDF_FILE_MB=25
MAX_QUESTION_CHARS=1000
MAX_CONTEXT_CHARS=12000
MAX_TOP_K=20

# Basic in-memory rate limiting
RATE_LIMIT_PER_MINUTE=30

# Storage
UPLOADS_DIR=uploads
